# Local Postgres (use your credentials)
DATABASE_URL="postgresql://user:pass@localhost:5432/vms_db?schema=public"

# API listen port
# - Dev default: 3000
# - Production example: 7700
PORT=3000

# Min 16 characters — required for the API to start (use a long random string in production)
JWT_SECRET="replace-with-long-random-secret"
JWT_EXPIRES_HOURS=8

# Comma-separated browser origins allowed for CORS (must include your Next.js origin)
# Local frontend default: http://localhost:3001
# Production example: https://app.example.com
CORS_ORIGINS=http://localhost:3001

# Optional: demo user password when running `npm run seed`
SEED_DEMO_PASSWORD=ChangeMe!123
