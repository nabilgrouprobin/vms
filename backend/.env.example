DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/vms_db?schema=public
# Generate a strong secret:  openssl rand -hex 48
JWT_SECRET=replace-with-long-random-secret-min-32-chars
JWT_EXPIRES_HOURS=8
PORT=4000
HOST=0.0.0.0
# Comma-separated list of allowed origins, or * for any.
CORS_ORIGINS=*
# Toggle public /auth/signup. Defaults to false in production.
ENABLE_PUBLIC_SIGNUP=false
