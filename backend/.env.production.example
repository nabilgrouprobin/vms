NODE_ENV=production
PORT=7700

# Production Postgres (replace user/pass/db/host)
DATABASE_URL="postgresql://user:pass@127.0.0.1:5432/vms_db?schema=public"

# Use a long random string in production
JWT_SECRET="replace-with-long-random-secret"
JWT_EXPIRES_HOURS=8

# Comma-separated browser origins allowed for CORS
# If you're using Nginx with a domain, prefer ONLY the domain origin(s).
# Examples:
#   CORS_ORIGINS=https://your-domain.com
#   CORS_ORIGINS=https://app.your-domain.com,https://admin.your-domain.com
CORS_ORIGINS=http://27.147.128.177

# Optional: demo user password when running `npm run seed` (avoid in production)
SEED_DEMO_PASSWORD=ChangeMe!123
