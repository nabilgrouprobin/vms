  paymentTerms   String?  @map("payment_terms")
  creditLimitMt  Decimal? @map("credit_limit_mt") @db.Decimal(18, 3)
  rating         Int?     @default(3)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization        @relation("CarrierCompany", fields: [organizationId], references: [id])
  lighters     Lighter[]
  assignments  LighterAssignment[]

  @@index([organizationId])
  @@index([isActive])
  @@map("carriers")
}

model Lighter {
  id             String    @id @default(cuid())
  name           String
  registrationNo String?   @unique @map("registration_no")
  carrierId      String    @map("carrier_id")
  capacityMt     Decimal   @map("capacity_mt") @db.Decimal(18, 3)
  lengthM        Float?    @map("length_m")
  draftM         Float?    @map("draft_m")
  engineHp       Int?      @map("engine_hp")
  hasFender      Boolean   @default(true) @map("has_fender")
  hasCover       Boolean   @default(false) @map("has_cover")
  lastSurveyDate DateTime? @map("last_survey_date")
  nextSurveyDate DateTime? @map("next_survey_date")
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  carrier        Carrier             @relation(fields: [carrierId], references: [id])
  assignments    LighterAssignment[]
  stockMovements StockMovement[]

  @@index([carrierId])
  @@index([registrationNo])
  @@index([isActive])
  @@map("lighters")
}

model LighterAssignment {
  id                      String           @id @default(cuid())
  assignmentNo            String           @unique @map("assignment_no")
  carrierId               String           @map("carrier_id")
  lighterId               String           @map("lighter_id")
  lcId                    String?          @map("lc_id")
  lcReleaseId             String?          @map("lc_release_id")
  vesselCallId            String           @map("vessel_call_id")
  costBearingScope        CostBearingScope @default(PORT_ONLY) @map("cost_bearing_scope")
  freightRateUsd          Decimal?         @map("freight_rate_usd") @db.Decimal(18, 2)
  totalFreightUsd         Decimal?         @map("total_freight_usd") @db.Decimal(18, 2)
  deliveryDestination     String?          @map("delivery_destination")
  destinationGhatId       String           @map("destination_ghat_id")
  estimatedQtyMt          Decimal          @map("estimated_qty_mt") @db.Decimal(18, 3)
  surveyorLoadedQtyMt     Decimal?         @map("surveyor_loaded_qty_mt") @db.Decimal(18, 3)
  actualDischargedQtyMt   Decimal?         @map("actual_discharged_qty_mt") @db.Decimal(18, 3)
  weightDifferenceMt      Decimal?         @map("weight_difference_mt") @db.Decimal(18, 3)
  weightDifferencePercent Decimal?         @map("weight_difference_percent") @db.Decimal(8, 4)
  assignedDate            DateTime         @default(now()) @map("assigned_date")
  carrierConfirmedDate    DateTime?        @map("carrier_confirmed_date")
  readyDate               DateTime?        @map("ready_date")
  departedDate            DateTime?        @map("departed_date")
  arrivedMvDate           DateTime?        @map("arrived_mv_date")
  alongsideDate           DateTime?        @map("alongside_date")
  loadingStartDate        DateTime?        @map("loading_start_date")
  loadingSuspendedDate    DateTime?        @map("loading_suspended_date")
  loadingResumedDate      DateTime?        @map("loading_resumed_date")
  loadingCompleteDate     DateTime?        @map("loading_complete_date")
  departedMvDate          DateTime?        @map("departed_mv_date")
  arrivedGhatDate         DateTime?        @map("arrived_ghat_date")
  unloadingStartDate      DateTime?        @map("unloading_start_date")
  unloadingSuspendedDate  DateTime?        @map("unloading_suspended_date")
  unloadingResumedDate    DateTime?        @map("unloading_resumed_date")
  unloadingCompleteDate   DateTime?        @map("unloading_complete_date")
  status                  LighterStatus    @default(ASSIGNED)
  holdReason              String?          @map("hold_reason")
  holdHours               Decimal?         @map("hold_hours") @db.Decimal(10, 2)
  dischargeStage          DischargeStage   @default(ANCHORAGE_DISCHARGE) @map("discharge_stage")
  stageQuantityMt         Decimal?         @map("stage_quantity_mt") @db.Decimal(18, 3)
  stageFreightRateUsd     Decimal?         @map("stage_freight_rate_usd") @db.Decimal(18, 2)
  assignedBy              String           @map("assigned_by")
  notes                   String?
  deletedAt               DateTime?        @map("deleted_at")
  createdAt               DateTime         @default(now()) @map("created_at")
  updatedAt               DateTime         @updatedAt @map("updated_at")

  carrier         Carrier         @relation(fields: [carrierId], references: [id])
  lighter         Lighter         @relation(fields: [lighterId], references: [id])
  letterOfCredit  LetterOfCredit? @relation(fields: [lcId], references: [id])
  lcRelease       LcRelease?      @relation(fields: [lcReleaseId], references: [id])
  vesselCall      VesselCall      @relation(fields: [vesselCallId], references: [id])
  destinationGhat Ghat            @relation(fields: [destinationGhatId], references: [id])
  assignedByUser  User            @relation("Assigner", fields: [assignedBy], references: [id])
  stockMovements  StockMovement[]
  ghatUnloading   GhatUnloading?
  trip            LighterTrip?
  draftSurveys    DraftSurvey[]

  @@index([vesselCallId])
  @@index([lcReleaseId])
  @@index([carrierId])
  @@index([lighterId])
  @@index([status, assignedDate])
  @@index([vesselCallId, status])
  @@index([destinationGhatId, status])
  @@index([deletedAt])
  @@index([dischargeStage])
  @@index([vesselCallId, dischargeStage, status])
  @@index([lighterId, status])
  @@index([destinationGhatId, assignedDate])
  @@map("lighter_assignments")
}

// ==================== SOF & LAYTIME MANAGEMENT ====================

model SofEventTypeDefinition {
  id        String               @id @default(cuid())
  code      String               @unique
  name      String
  scope     SofEventTypeScope    @default(BOTH)
  category  SofEventTypeCategory @default(NORMAL)
  isActive  Boolean              @default(true) @map("is_active")
  deletedAt DateTime?            @map("deleted_at")
  createdAt DateTime             @default(now()) @map("created_at")
  updatedAt DateTime             @updatedAt @map("updated_at")

  sofEvents      SofEvent[]
  hourlyStatuses SofHourlyStatus[]

  @@index([scope, isActive])
  @@index([isActive])
  @@index([category, isActive])
  @@map("sof_event_type_definitions")
}

model StatementOfFacts {
  id                   String    @id @default(cuid())
  sofNo                String    @unique @map("sof_no")
  scope                SOFScope  @default(MOTHER_VESSEL)
  vesselCallId         String?   @unique @map("vessel_call_id")
  lighterTripId        String?   @unique @map("lighter_trip_id")
  startedAt            DateTime? @map("started_at")
  completedAt          DateTime? @map("completed_at")
  status               SOFStatus @default(DRAFT)
  laytimeAllowedHours  Decimal?  @map("laytime_allowed_hours") @db.Decimal(12, 2)
  laytimeUsedHours     Decimal?  @map("laytime_used_hours") @db.Decimal(12, 2)
  laytimeExcludedHours Decimal?  @default(0) @map("laytime_excluded_hours") @db.Decimal(12, 2)
  laytimeBalanceHours  Decimal?  @map("laytime_balance_hours") @db.Decimal(12, 2)
  /// Snapshot of commence instant used for last laytime calculation
  laytimeCommenceAt    DateTime? @map("laytime_commence_at")
  demurrageAmount      Decimal?  @map("demurrage_amount") @db.Decimal(18, 2)
  dispatchAmount       Decimal?  @map("dispatch_amount") @db.Decimal(18, 2)
  netAmount            Decimal?  @map("net_amount") @db.Decimal(18, 2)
  verifiedBy           String?   @map("verified_by")
  verifiedAt           DateTime? @map("verified_at")
  approvedBy           String?   @map("approved_by")
  approvedAt           DateTime? @map("approved_at")
  remarks              String?
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  vesselCall     VesselCall?       @relation(fields: [vesselCallId], references: [id])
  lighterTrip    LighterTrip?      @relation(fields: [lighterTripId], references: [id])
  events         SofEvent[]
  hourlyStatuses SofHourlyStatus[]
  verifiedByUser User?             @relation("SofVerifier", fields: [verifiedBy], references: [id])

  @@index([sofNo])
  @@index([vesselCallId])
  @@index([lighterTripId])
  @@index([scope, status])
  @@index([status])
  @@index([scope, startedAt])
  @@index([scope, completedAt])
  @@map("statements_of_fact")
}

model SofEvent {
  id                    String       @id @default(cuid())
  statementId           String       @map("statement_id")
  eventTypeId           String       @map("event_type_id")
  eventTime             DateTime     @map("event_time")
  durationHours         Decimal?     @map("duration_hours") @db.Decimal(10, 2)
  /** Whole minutes from period start to `eventTime` (to); preferred over fractional `durationHours`. */
  durationMinutes       Int?         @map("duration_minutes")
  countsAsLaytime       Boolean      @default(true) @map("counts_as_laytime")
  laytimeImpactHours    Decimal?     @map("laytime_impact_hours") @db.Decimal(10, 2)
  location              String?
  anchorageId           String?      @map("anchorage_id")
  robQuantityMt         Decimal?     @map("rob_quantity_mt") @db.Decimal(18, 3)
  dischargeQuantityMt   Decimal?     @map("discharge_quantity_mt") @db.Decimal(18, 3)
  cumulativeDischargeMt Decimal?     @map("cumulative_discharge_mt") @db.Decimal(18, 3)
  isHold                Boolean      @default(false) @map("is_hold")
  holdReason            String?      @map("hold_reason")
  responsibleParty      String?      @map("responsible_party")
  laytimeAccount        String?      @map("laytime_account")
  referenceNo           String?      @map("reference_no")
  remarks               String?
  supportingDocuments   String[]     @map("supporting_documents")
  createdBy             String       @map("created_by")
  verifiedBy            String?      @map("verified_by")
  verifiedAt            DateTime?    @map("verified_at")
  operationBatchId      String?      @map("operation_batch_id")
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")

  statement            StatementOfFacts       @relation(fields: [statementId], references: [id])
  eventTypeDefinition  SofEventTypeDefinition @relation(fields: [eventTypeId], references: [id])
  anchorage            Anchorage?             @relation(fields: [anchorageId], references: [id])
  createdByUser        User                   @relation("SofEventCreator", fields: [createdBy], references: [id])
  verifiedByUser User?               @relation("SofEventVerifier", fields: [verifiedBy], references: [id])
  operationBatch BulkOperationBatch? @relation("SofEventBatch", fields: [operationBatchId], references: [id])

  @@index([statementId])
  @@index([eventTypeId])
  @@index([eventTime])
  @@index([isHold])
  @@index([statementId, eventTime])
  @@index([eventTypeId, eventTime])
  @@index([isHold, eventTime])
  @@index([anchorageId, eventTime])
  @@index([statementId, eventTypeId, eventTime])
  @@index([statementId, isHold, eventTime])
  @@index([createdBy, createdAt])
  @@index([verifiedBy, verifiedAt])
  @@index([operationBatchId, eventTime])
  @@index([eventTime, id])
  @@index([statementId, eventTime, id])
  @@map("sof_events")
}

model MotherVesselDailyDischarge {
  id            String   @id @default(cuid())
  vesselCallId  String   @map("vessel_call_id")
  reportDate    DateTime @map("report_date")
  quantity24hMt Decimal  @map("quantity_24h_mt") @db.Decimal(18, 3)
  cumulativeMt  Decimal? @map("cumulative_mt") @db.Decimal(18, 3)
  remainingMt   Decimal? @map("remaining_mt") @db.Decimal(18, 3)
  enteredById   String?  @map("entered_by_id")
  remarks       String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  vesselCall     VesselCall        @relation(fields: [vesselCallId], references: [id])
  enteredBy      User?             @relation("DailyDischargeEnteredBy", fields: [enteredById], references: [id])
  hourlyStatuses SofHourlyStatus[]

  @@unique([vesselCallId, reportDate])
  @@index([reportDate])
  @@index([enteredById])
  @@index([vesselCallId, reportDate, createdAt])
  @@index([createdAt])
  @@map("mother_vessel_daily_discharges")
}

model SofHourlyStatus {
  id               String        @id @default(cuid())
  statementId      String        @map("statement_id")
  dailyDischargeId String?       @map("daily_discharge_id")
  lighterTripId    String?       @map("lighter_trip_id")
  hourStartAt      DateTime      @map("hour_start_at")
  hourEndAt        DateTime?     @map("hour_end_at")
  eventTypeId      String?       @map("event_type_id")
  statusText       String        @map("status_text")
  dischargeQtyMt   Decimal?      @map("discharge_qty_mt") @db.Decimal(18, 3)
  cumulativeMt     Decimal?      @map("cumulative_mt") @db.Decimal(18, 3)
  robQtyMt         Decimal?      @map("rob_qty_mt") @db.Decimal(18, 3)
  holdReason       String?       @map("hold_reason")
  remarks          String?
  createdById      String?       @map("created_by_id")
  operationBatchId String?       @map("operation_batch_id")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  statement           StatementOfFacts            @relation(fields: [statementId], references: [id])
  dailyDischarge      MotherVesselDailyDischarge? @relation(fields: [dailyDischargeId], references: [id])
  lighterTrip         LighterTrip?                @relation(fields: [lighterTripId], references: [id])
  eventTypeDefinition SofEventTypeDefinition?     @relation(fields: [eventTypeId], references: [id])
  createdBy           User?                       @relation("SofHourlyStatusCreator", fields: [createdById], references: [id])
  operationBatch BulkOperationBatch?         @relation("SofHourlyStatusBatch", fields: [operationBatchId], references: [id])

  @@unique([statementId, hourStartAt])
  @@index([dailyDischargeId])
  @@index([lighterTripId])
  @@index([hourStartAt])
  @@index([eventTypeId])
  @@index([dailyDischargeId, hourStartAt])
  @@index([lighterTripId, hourStartAt])
  @@index([eventTypeId, hourStartAt])
  @@index([statementId, eventTypeId, hourStartAt])
  @@index([createdById, createdAt])
  @@index([operationBatchId, hourStartAt])
  @@index([hourStartAt, id])
  @@map("sof_hourly_statuses")
}

// ==================== LIGHTER TRIP & OPERATIONS ====================

model LighterTrip {
  id                     String              @id @default(cuid())
  tripNo                 String              @unique @map("trip_no")
  vesselCallId           String              @map("vessel_call_id")
  /// Optional lighter-hull **port visit** (`VesselCall` where vessel is a lighter); for deep-links and ops context.
  lighterPortCallId      String?             @map("lighter_port_call_id")
  lighterAssignmentId    String?             @unique @map("lighter_assignment_id")
  lighterVesselId        String              @map("lighter_vessel_id")
  assignedById           String?             @map("assigned_by_id")
  returnLocationId       String?             @map("return_location_id")
  destinationType        SaleAllocationType? @map("destination_type")
  masterName             String?             @map("master_name")
  masterPhone            String?             @map("master_phone")
  masterLicenseNo        String?             @map("master_license_no")
  assistantName          String?             @map("assistant_name")
  assistantPhone         String?             @map("assistant_phone")
  numberOfCrew           Int?                @default(2) @map("number_of_crew")
  lighterCapacityTon     Decimal?            @map("lighter_capacity_ton") @db.Decimal(18, 3)
  hasSurveyorScout       Boolean?            @default(false) @map("has_surveyor_scout")
  hasImporterScout       Boolean?            @default(false) @map("has_importer_scout")
  surveyorScoutBoardedAt DateTime?           @map("surveyor_scout_boarded_at")
  importerScoutBoardedAt DateTime?           @map("importer_scout_boarded_at")
  assignedAt             DateTime            @default(now()) @map("assigned_at")
  /// Laytime commence for lighter SOF (falls back to loadingStartedAt / wayToMVStartedAt in calculator)
  laytimeCommenceAt      DateTime?           @map("laytime_commence_at")
  wayToMVReadyAt         DateTime?           @map("way_to_mv_ready_at")
  wayToMVStartedAt       DateTime?           @map("way_to_mv_started_at")
  wayToMVCompletedAt     DateTime?           @map("way_to_mv_completed_at")
  alongsideDate          DateTime?           @map("alongside_date")
  loadingStartedAt       DateTime?           @map("loading_started_at")
  loadingCompletedAt     DateTime?           @map("loading_completed_at")
  draftSurveyId          String?             @unique @map("draft_survey_id")
  draftSurveyWeightMt    Decimal?            @map("draft_survey_weight_mt") @db.Decimal(18, 3)
  draftSurveyStatus      String?             @map("draft_survey_status")
  departedMvDate         DateTime?           @map("departed_mv_date")
  wayToGhatStartedAt     DateTime?           @map("way_to_ghat_started_at")
  wayToGhatCompletedAt   DateTime?           @map("way_to_ghat_completed_at")
  arrivedGhatDate        DateTime?           @map("arrived_ghat_date")
  unloadStartedAt        DateTime?           @map("unload_started_at")
  unloadCompletedAt      DateTime?           @map("unload_completed_at")
  status                 LighterTripStatus   @default(PLANNED)
  remarks                String?
  paymentStatus          PaymentStatus?      @default(PENDING) @map("payment_status")
  holdReason             String?             @map("hold_reason")
  deletedAt              DateTime?           @map("deleted_at")
  createdAt              DateTime            @default(now()) @map("created_at")
  updatedAt              DateTime            @updatedAt @map("updated_at")

  vesselCall         VesselCall          @relation("LighterTripMotherCall", fields: [vesselCallId], references: [id])
  lighterPortCall    VesselCall?         @relation("LighterTripLighterPortCall", fields: [lighterPortCallId], references: [id])
  lighterAssignment  LighterAssignment?  @relation(fields: [lighterAssignmentId], references: [id])
  lighterVessel      Vessel              @relation(fields: [lighterVesselId], references: [id])
  assignedBy         User?               @relation("TripAssignedBy", fields: [assignedById], references: [id])
  returnLocation     Location?           @relation("TripReturnLocation", fields: [returnLocationId], references: [id])
  cargoes            LighterTripCargo[]
  events             LighterTripEvent[]
  stockMovements     StockMovement[]
  unloadingOperation UnloadingOperation?
  siloReceipts       SiloReceipt[]
  statementOfFacts   StatementOfFacts?
  sofHourlyStatuses  SofHourlyStatus[]
  scouts             LighterScout[]
  draftSurveys       DraftSurvey[]

  @@index([vesselCallId])
  @@index([lighterPortCallId])
  @@index([lighterVesselId])
  @@index([status, createdAt])
  @@index([tripNo])
  @@index([deletedAt])
  @@index([paymentStatus])
  @@index([hasSurveyorScout, hasImporterScout])
  @@index([draftSurveyStatus])
  @@index([vesselCallId, status, assignedAt])
  @@index([lighterVesselId, status])
  @@index([arrivedGhatDate, status])
  @@index([wayToMVStartedAt, status])
  @@index([paymentStatus, assignedAt])
  @@index([destinationType, status, assignedAt])
  @@index([loadingStartedAt, status])
  @@index([loadingCompletedAt, status])
  @@index([unloadCompletedAt, status])
  @@map("lighter_trips")
}

model LighterTripCargo {
  id               String        @id @default(cuid())
  tripId           String        @map("trip_id")
  productId        String        @map("product_id")
  lcReleaseId      String?       @map("lc_release_id")
  estimatedQtyTon  Decimal?      @map("estimated_qty_ton") @db.Decimal(18, 3)
  agreedQtyTon     Decimal?      @map("agreed_qty_ton") @db.Decimal(18, 3)
  loadedQtyTon     Decimal?      @map("loaded_qty_ton") @db.Decimal(18, 3)
  dischargedQtyTon Decimal?      @map("discharged_qty_ton") @db.Decimal(18, 3)
  differenceQtyTon Decimal?      @map("difference_qty_ton") @db.Decimal(18, 3)
  differencePct    Decimal?      @map("difference_pct") @db.Decimal(5, 2)
  weightSource     WeightSource? @map("weight_source")
  remarks          String?

  trip      LighterTrip @relation(fields: [tripId], references: [id])
  product   Product     @relation(fields: [productId], references: [id])
  lcRelease LcRelease?  @relation(fields: [lcReleaseId], references: [id])

  @@unique([tripId, productId])
  @@index([lcReleaseId])
  @@index([tripId, productId, lcReleaseId])
  @@index([productId, lcReleaseId])
  @@map("lighter_trip_cargoes")
}

model LighterTripEvent {
  id               String             @id @default(cuid())
  tripId           String             @map("trip_id")
  eventTime        DateTime           @default(now()) @map("event_time")
  statusAfter      LighterTripStatus? @map("status_after")
  direction        EventDirection?
  remarks          String?
  operationBatchId String?            @map("operation_batch_id")

  trip           LighterTrip         @relation(fields: [tripId], references: [id])
  operationBatch BulkOperationBatch? @relation("LighterTripEventBatch", fields: [operationBatchId], references: [id])

  @@index([tripId])
  @@index([eventTime])
  @@index([tripId, eventTime])
  @@index([tripId, eventTime, id])
  @@index([statusAfter, eventTime])
  @@index([direction, eventTime])
  @@index([tripId, statusAfter, eventTime])
  @@index([operationBatchId, eventTime])
  @@index([eventTime, id])
  @@map("lighter_trip_events")
}

model LighterScout {
  id             String    @id @default(cuid())
  lighterTripId  String    @map("lighter_trip_id")
  scoutType      ScoutType @map("scout_type")
  scoutName      String    @map("scout_name")
  scoutPhone     String?   @map("scout_phone")
  scoutNid       String?   @map("scout_nid")
  organizationId String?   @map("organization_id")
  assignedAt     DateTime  @default(now()) @map("assigned_at")
  boardedAt      DateTime? @map("boarded_at")
  disembarkedAt  DateTime? @map("disembarked_at")
  status         String    @default("ASSIGNED") @map("status")
  remarks        String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  lighterTrip  LighterTrip   @relation(fields: [lighterTripId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])

  @@unique([lighterTripId, scoutType])
  @@index([lighterTripId])
  @@index([scoutType, status])
  @@map("lighter_scouts")
}

// ==================== DRAFT SURVEY (ARCHIMEDES) ====================

model DraftSurvey {
  id                            String    @id @default(cuid())
  surveyNo                      String    @unique @map("survey_no")
  lighterTripId                 String    @unique @map("lighter_trip_id")
  lighterAssignmentId           String?   @map("lighter_assignment_id")
  surveyorId                    String?   @map("surveyor_id")
  surveyedByUserId              String?   @map("surveyed_by_user_id")
  surveyLocation                String    @map("survey_location")
  locationId                    String?   @map("location_id")
  waterDensity                  Decimal?  @map("water_density") @db.Decimal(5, 3)
  waterTemperature              Decimal?  @map("water_temperature") @db.Decimal(5, 2)
  windSpeedKnots                Decimal?  @map("wind_speed_knots") @db.Decimal(5, 2)
  waveHeightMeters              Decimal?  @map("wave_height_meters") @db.Decimal(4, 2)
  isTidalInfluence              Boolean?  @default(false) @map("is_tidal_influence")
  tideCondition                 String?   @map("tide_condition")
  preLoadDraftForward           Decimal?  @map("pre_load_draft_forward") @db.Decimal(5, 3)
  preLoadDraftMid               Decimal?  @map("pre_load_draft_mid") @db.Decimal(5, 3)
  preLoadDraftAft               Decimal?  @map("pre_load_draft_aft") @db.Decimal(5, 3)
  preLoadDraftMean              Decimal?  @map("pre_load_draft_mean") @db.Decimal(5, 3)
  preLoadDisplacement           Decimal?  @map("pre_load_displacement") @db.Decimal(18, 3)
  preLoadBallastWaterMt         Decimal?  @default(0) @map("pre_load_ballast_water_mt") @db.Decimal(18, 3)
  preLoadFreshWaterMt           Decimal?  @default(0) @map("pre_load_fresh_water_mt") @db.Decimal(18, 3)
  preLoadFuelOilMt              Decimal?  @default(0) @map("pre_load_fuel_oil_mt") @db.Decimal(18, 3)
