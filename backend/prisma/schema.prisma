model ProformaInvoice {
  id                     String         @id @default(cuid())
  piNo                   String         @unique @map("pi_no")
  piDate                 DateTime?      @map("pi_date")
  validityDate           DateTime?      @map("validity_date")
  contractNo             String?        @map("contract_no")
  contractDate           DateTime?      @map("contract_date")
  sellerId               String?        @map("seller_id")
  buyerId                String?        @map("buyer_id")
  consignee              String?        @default("To Order") @map("consignee")
  vesselTerms            String?        @default("By Sea") @map("vessel_terms")
  portOfLoading          String?        @map("port_of_loading")
  countryOfOrigin        String?        @map("country_of_origin")
  countryOfDestination   String?        @map("country_of_destination")
  portOfDischarge        String?        @map("port_of_discharge")
  finalDestination       String?        @map("final_destination")
  deliveryTerms          String?        @map("delivery_terms")
  deliveryTermsDetails   String?        @map("delivery_terms_details")
  paymentTerms           String?        @map("payment_terms")
  quantityMt             Decimal?       @map("quantity_mt") @db.Decimal(18, 3)
  tolerancePercent       Decimal?       @default(10.00) @map("tolerance_percent") @db.Decimal(5, 2)
  toleranceOption        String?        @default("SELLER'S OPTION") @map("tolerance_option")
  productDescription     String?        @map("product_description")
  hsCode                 String?        @map("hs_code")
  packing                String?        @default("IN BULK") @map("packing")
  marksAndNos            String?        @default("NIL") @map("marks_and_nos")
  specMoisturePct        Decimal?       @map("spec_moisture_pct") @db.Decimal(5, 2)
  specTotalDamagePct     Decimal?       @map("spec_total_damage_pct") @db.Decimal(5, 2)
  specBrokenPct          Decimal?       @map("spec_broken_pct") @db.Decimal(5, 2)
  specForeignMatterPct   Decimal?       @map("spec_foreign_matter_pct") @db.Decimal(5, 2)
  specAflaxonPpb         Int?           @map("spec_aflaxon_ppb")
  ratePerMt              Decimal?       @map("rate_per_mt") @db.Decimal(18, 4)
  currency               String?        @default("USD")
  fobValue               Decimal?       @map("fob_value") @db.Decimal(18, 2)
  freightValue           Decimal?       @map("freight_value") @db.Decimal(18, 2)
  totalValue             Decimal?       @map("total_value") @db.Decimal(18, 2)
  totalValueInWords      String?        @map("total_value_in_words")
  beneficiaryBankName    String?        @map("beneficiary_bank_name")
  beneficiaryBankAddress String?        @map("beneficiary_bank_address")
  beneficiaryBankSwift   String?        @map("beneficiary_bank_swift")
  shipmentDeadline       DateTime?      @map("shipment_deadline")
  status                 DocumentStatus @default(DRAFT)
  companyCode            String?        @map("company_code")
  addedById              String?        @map("added_by_id")
  modifiedById           String?        @map("modified_by_id")
  approvedById           String?        @map("approved_by_id")
  approvedAt             DateTime?      @map("approved_at")
  rejectionReason        String?        @map("rejection_reason")
  entryDate              DateTime?      @map("entry_date")
  deletedAt              DateTime?      @map("deleted_at")
  createdAt              DateTime       @default(now()) @map("created_at")
  updatedAt              DateTime       @updatedAt @map("updated_at")

  seller         Organization?    @relation("PiSeller", fields: [sellerId], references: [id])
  buyer          Organization?    @relation("PiBuyer", fields: [buyerId], references: [id])
  addedBy        User?            @relation("PiAddedBy", fields: [addedById], references: [id])
  modifiedBy     User?            @relation("PiModifiedBy", fields: [modifiedById], references: [id])
  approvedBy     User?            @relation("PiApprovedBy", fields: [approvedById], references: [id])
  items          PiItem[]
  lcs            LetterOfCredit[]
  lcApplications LcApplication[]

  @@index([piNo])
  @@index([status])
  @@index([contractNo])
  @@index([approvedById])
  @@index([sellerId, status])
  @@index([buyerId, status])
  @@index([piDate, status])
  @@map("proforma_invoices")
}

model PiItem {
  id          String   @id @default(cuid())
  piId        String   @map("pi_id")
  lineNo      Int      @map("line_no")
  productId   String   @map("product_id")
  lcQty       Decimal? @map("lc_qty") @db.Decimal(18, 3)
  blQty       Decimal? @map("bl_qty") @db.Decimal(18, 3)
  receivedQty Decimal? @map("received_qty") @db.Decimal(18, 3)
  lcWeightTon Decimal? @map("lc_weight_ton") @db.Decimal(18, 3)

  pi      ProformaInvoice @relation(fields: [piId], references: [id])
  product Product         @relation(fields: [productId], references: [id])

  @@unique([piId, lineNo])
  @@map("pi_items")
}

