// ==================== CORE MODELS ====================

model OrganizationTypeDefinition {
  id        String    @id @default(cuid())
  code      String    @unique
  name      String
  isActive  Boolean   @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  organizations Organization[]

  @@index([isActive])
  @@map("organization_type_definitions")
}

model Organization {
  id      String @id @default(cuid())
  code    String @unique
  name    String
  /** Classification for counterparties (managed under Master → Organization types). */
  organizationTypeId String                 @map("organization_type_id")
  organizationType   OrganizationTypeDefinition @relation(fields: [organizationTypeId], references: [id])
  address            String?

  // Owner Contact
  ownerName  String? @map("owner_name")
  ownerPhone String? @map("owner_phone")
  ownerEmail String? @map("owner_email")

  // Manager Contact
  managerName  String? @map("manager_name")
  managerPhone String? @map("manager_phone")
  managerEmail String? @map("manager_email")

  // General Contact (fallback/alternative)
  contactPerson String? @map("contact_person")
  contactNo     String? @map("contact_no")
  email         String?

  taxId          String?   @unique
  registrationNo String?   @unique
  website        String?
  currentStatus  String?   @default("ACTIVE")
  companyCode    String?
  isActive       Boolean   @default(true)
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // Relations
  users                    User[]
  supplierContracts        ImportContract[]     @relation("ContractSupplier")
  buyerContracts           ImportContract[]     @relation("ContractBuyer")
  lcApplicant              LetterOfCredit[]     @relation("LcApplicant")
  lcBeneficiary            LetterOfCredit[]     @relation("LcBeneficiary")
  lcIssuingBank            LetterOfCredit[]     @relation("LcIssuingBank")
  lcDrawee                 LetterOfCredit[]     @relation("LcDrawee")
  piSellers                ProformaInvoice[]    @relation("PiSeller")
  piBuyers                 ProformaInvoice[]    @relation("PiBuyer")
  vesselShippingAgent      VesselCall[]         @relation("CallShippingAgent")
  vesselStevedore          VesselCall[]         @relation("CallStevedore")
  vesselCnfList            VesselCall[]         @relation("CallCnf")
  carrierFleet             Carrier[]            @relation("CarrierCompany")
  truckOwners              Truck[]
  lighterScouts            LighterScout[]
  draftSurveyOrgs          DraftSurvey[]        @relation("DraftSurveyOrg")
  draftSurveySurveyors     DraftSurvey[]        @relation("DraftSurveySurveyor")
  commercialInvoiceSellers CommercialInvoice[]  @relation("CommercialInvoiceSeller")
  commercialInvoiceBuyers  CommercialInvoice[]  @relation("CommercialInvoiceBuyer")
  blShippers               BillOfLading[]       @relation("BlShipper")
  blNotifyParties          BillOfLading[]       @relation("BlNotifyParty")
  blApplicants             BillOfLading[]       @relation("BlApplicant")
  packingListConsignees    PackingList[]        @relation("PackingListConsignee")
  procurementRequests      ProcurementRequest[] @relation("ProcurementBuyer")
  brokerEngagements        BrokerEngagement[]   @relation("BrokerOrg")
  brokerSuppliers          BrokerEngagement[]   @relation("BrokerSupplier")
  supplierOffers           SupplierOffer[]      @relation("OfferSupplier")
  permitApplicants         ImportPermit[]       @relation("PermitApplicant")
  creditLimitBanks         BankCreditLimit[]    @relation("CreditLimitBank")
  creditLimitApplicants    BankCreditLimit[]    @relation("CreditLimitApplicant")
  norSenders               NoticeOfReadiness[]  @relation("NorSender")

  @@index([organizationTypeId])
  @@index([isActive])
  @@index([deletedAt])
  @@map("organizations")
}

model User {
  id             String    @id @default(cuid())
  email          String?   @unique
  phone          String    @unique
  fullName       String
  passwordHash   String?   @map("password_hash")
  isActive       Boolean   @default(true)
  lastLoginAt    DateTime? @map("last_login_at")
  organizationId String?
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization             Organization?                @relation(fields: [organizationId], references: [id])
  roles                    UserRoleAssignment[]         @relation("UserRoles")
  grantedRoles             UserRoleAssignment[]         @relation("RoleGrantor")
  addedLcs                 LetterOfCredit[]             @relation("LcAddedBy")
  modifiedLcs              LetterOfCredit[]             @relation("LcModifiedBy")
  approvedLcAmendments     LcAmendment[]                @relation("LCAmendmentApprovedBy")
  requestedLcAmendments    LcAmendment[]                @relation("LCAmendmentRequestedBy")
  addedPis                 ProformaInvoice[]            @relation("PiAddedBy")
  modifiedPis              ProformaInvoice[]            @relation("PiModifiedBy")
  addedCalls               VesselCall[]                 @relation("CallAddedBy")
  updatedCalls             VesselCall[]                 @relation("CallUpdatedBy")
  createdTrips             LighterTrip[]                @relation("TripAssignedBy")
  releasedLcQuantities     LcRelease[]                  @relation("LcReleaseReleasedBy")
  approvedLcReleases       LcRelease[]                  @relation("LcReleaseApprovedBy")
  lighterAssignments       LighterAssignment[]          @relation("Assigner")
  sofEvents                SofEvent[]                   @relation("SofEventCreator")
  sofVerifications         SofEvent[]                   @relation("SofEventVerifier")
  dailyDischargesEntered   MotherVesselDailyDischarge[] @relation("DailyDischargeEnteredBy")
  sofHourlyStatusesCreated SofHourlyStatus[]            @relation("SofHourlyStatusCreator")
  verifiedStatements       StatementOfFacts[]           @relation("SofVerifier")
  draftSurveys             DraftSurvey[]                @relation("DraftSurveyUser")
  surveyedByUser           DraftSurvey[]                @relation("DraftSurveySurveyedBy")
  requestedProcurements    ProcurementRequest[]         @relation("ProcurementRequestedBy")
  approvedProcurements     ProcurementRequest[]         @relation("ProcurementApprovedBy")
  approvedContracts        ImportContract[]             @relation("ContractApprovedBy")
  approvedPis              ProformaInvoice[]            @relation("PiApprovedBy")
  approvedPermits          ImportPermit[]               @relation("PermitApprovedBy")
  collectedRegulatoryDocs  RegulatoryClearance[]        @relation("RegulatoryCollectedBy")
  requestedLcApplications  LcApplication[]              @relation("LcApplicationRequestedBy")
  reviewedLcApplications   LcApplication[]              @relation("LcApplicationReviewedBy")
  receivedNors             NoticeOfReadiness[]          @relation("NorReceivedBy")
  sessions                 UserSession[]

  @@index([organizationId])
  @@index([email, isActive])
  @@index([organizationId, isActive])
  @@index([deletedAt])
  @@map("users")
}

model UserRoleAssignment {
  id         String    @id @default(cuid())
  userId     String
  role       AppRole
  locationId String?
  grantedBy  String?
  grantedAt  DateTime  @default(now())
  expiresAt  DateTime?
  createdAt  DateTime  @default(now()) @map("created_at")

  user     User      @relation("UserRoles", fields: [userId], references: [id])
  location Location? @relation(fields: [locationId], references: [id])
  grantor  User?     @relation("RoleGrantor", fields: [grantedBy], references: [id])

  @@unique([userId, role, locationId])
  @@index([role])
  @@index([expiresAt])
  @@map("user_roles")
}

// ==================== LOCATION & INFRASTRUCTURE ====================

model Location {
  id         String       @id @default(cuid())
  code       String       @unique
  name       String
  type       LocationType
  address    String?
  district   String?
  division   String?
  country    String       @default("Bangladesh")
  postalCode String?      @map("postal_code")
  isActive   Boolean      @default(true)
  deletedAt  DateTime?    @map("deleted_at")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  userRoles                  UserRoleAssignment[]
  vesselCalls                VesselCall[]         @relation("CallArrivalLocation")
  returnTrips                LighterTrip[]        @relation("TripReturnLocation")
  truckLoadDestinations      TruckLoad[]          @relation("TruckLoadDestination")
  stockMovementFromLocations StockMovement[]      @relation("StockMovementFromLocation")
  stockMovementToLocations   StockMovement[]      @relation("StockMovementToLocation")
  ghats                      Ghat[]
  warehouses                 Warehouse[]
  silos                      Silo[]
  anchorages                 Anchorage[]
  draftSurveys               DraftSurvey[]

  @@unique([code, type])
  @@index([type])
  @@index([district])
  @@index([isActive])
  @@map("locations")
}

model Anchorage {
  id         String   @id @default(cuid())
  code       String   @unique
  name       String
  locationId String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
