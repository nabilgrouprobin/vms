// ==================== VESSEL & MARITIME OPERATIONS ====================

model Vessel {
  id             String   @id @default(cuid())
  name           String   @unique
  imoNo          String?  @unique @map("imo_no")
  vesselType     String?  @map("vessel_type")
  flag           String?
  deadweightTon  Decimal? @map("deadweight_ton") @db.Decimal(18, 3)
  maxDraftMeters Decimal? @map("max_draft_meters") @db.Decimal(8, 3)
  lengthOverallM Decimal? @map("length_overall_m") @db.Decimal(8, 2)
  beamM          Decimal? @map("beam_m") @db.Decimal(8, 2)
  yearBuilt      Int?     @map("year_built")
  isMotherVessel Boolean  @default(false) @map("is_mother_vessel")
  isLighter      Boolean  @default(false) @map("is_lighter")
  /// Monotonic registry id (3-digit in call/trip numbers). Unique across mother + lighter hulls.
  hullDisplayCode Int      @unique @default(0) @map("hull_display_code")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  motherCalls    VesselCall[]
  lighterTrips   LighterTrip[]
  stockMovements StockMovement[]

  @@index([name])
  @@index([imoNo])
  @@index([isMotherVessel])
  @@map("vessels")
}

model VesselCall {
  id                         String             @id @default(cuid())
  callNo                     String             @unique @map("call_no")
  vesselId                   String             @map("vessel_id")
  importContractId           String?            @map("import_contract_id")
  arrivalLocationId          String?            @map("arrival_location_id")
  shippingAgentId            String?            @map("shipping_agent_id")
  stevedoreId                String?            @map("stevedore_id")
  cnfId                      String?            @map("cnf_id")
  eta                        DateTime?          @map("eta")
  etd                        DateTime?          @map("etd")
  ata                        DateTime?          @map("ata")
  atd                        DateTime?          @map("atd")
  anchorDroppedAt            DateTime?          @map("anchor_dropped_at")
  norTenderedAt              DateTime?          @map("nor_tendered_at")
  norAcceptedAt              DateTime?          @map("nor_accepted_at")
  norRejectedAt              DateTime?          @map("nor_rejected_at")
  norRejectionReason         String?            @map("nor_rejection_reason")
  norNumber                  String?            @map("nor_number")
  /// IANA zone for laytime calendar (excluded weekdays); app defaults when null
  laytimeTimeZone            String?            @map("laytime_time_zone") @db.VarChar(64)
  laytimeCommenceAt          DateTime?          @map("laytime_commence_at")
  igmDate                    DateTime?          @map("igm_date")
  customsClearanceDate       DateTime?          @map("customs_clearance_date")
  quarantineClearanceDate    DateTime?          @map("quarantine_clearance_date")
  portAuthorityClearanceDate DateTime?          @map("port_authority_clearance_date")
  readyToDischargeAt         DateTime?          @map("ready_to_discharge_at")
  dischargeStartedAt         DateTime?          @map("discharge_started_at")
  dischargeCompletedAt       DateTime?          @map("discharge_completed_at")
  anchorUpAt                 DateTime?          @map("anchor_up_at")
  cargoNameSnapshot          String?            @map("cargo_name_snapshot")
  approxTotalWeightTon       Decimal?           @map("approx_total_weight_ton") @db.Decimal(18, 3)
  toleranceMinusPct          Decimal?           @map("tolerance_minus_pct") @db.Decimal(5, 2)
  tolerancePlusPct           Decimal?           @map("tolerance_plus_pct") @db.Decimal(5, 2)
  holdReason                 String?            @map("hold_reason")
  status                     MotherVesselStatus @default(EXPECTED)
  currentAnchorage           String?            @map("current_anchorage")
  isAnchored                 Boolean?           @default(false) @map("is_anchored")
  isAlongside                Boolean?           @default(false) @map("is_alongside")
  addedById                  String?            @map("added_by_id")
  updatedById                String?            @map("updated_by_id")
  totalStages                Int                @default(1) @map("total_stages")
  completedStages            Int                @default(0) @map("completed_stages")
  lastStageCompletedAt       DateTime?          @map("last_stage_completed_at")
  nextStageExpectedAt        DateTime?          @map("next_stage_expected_at")
  anchorageDischargeMt       Decimal?           @default(0) @map("anchorage_discharge_mt") @db.Decimal(18, 3)
  alongsideDischargeMt       Decimal?           @default(0) @map("alongside_discharge_mt") @db.Decimal(18, 3)
  totalDischargeMt           Decimal?           @default(0) @map("total_discharge_mt") @db.Decimal(18, 3)
  createdAt                  DateTime           @default(now()) @map("created_at")
  updatedAt                  DateTime           @updatedAt @map("updated_at")

  vessel                   Vessel                       @relation(fields: [vesselId], references: [id])
  importContract           ImportContract?              @relation(fields: [importContractId], references: [id])
  arrivalLocation          Location?                    @relation("CallArrivalLocation", fields: [arrivalLocationId], references: [id])
  shippingAgent            Organization?                @relation("CallShippingAgent", fields: [shippingAgentId], references: [id])
  stevedore                Organization?                @relation("CallStevedore", fields: [stevedoreId], references: [id])
  cnf                      Organization?                @relation("CallCnf", fields: [cnfId], references: [id])
  addedBy                  User?                        @relation("CallAddedBy", fields: [addedById], references: [id])
  updatedBy                User?                        @relation("CallUpdatedBy", fields: [updatedById], references: [id])
  cargoLines               VesselCargoLine[]
  lcReleases               LcRelease[]
  lighterTrips             LighterTrip[] @relation("LighterTripMotherCall")
  lighterPortTrips        LighterTrip[] @relation("LighterTripLighterPortCall")
  statementOfFacts         StatementOfFacts?
  dailyDischarges          MotherVesselDailyDischarge[]
  lighterAssignments       LighterAssignment[]
  stockMovements           StockMovement[]
  billOfLading             BillOfLading?
  holdCleaningCertificates HoldCleaningCertificate[]
  regulatoryClearances     RegulatoryClearance[]
  noticesOfReadiness       NoticeOfReadiness[]
  vesselShifts             VesselShift[]
  cargoSummaries           VesselCargoSummary[]

  @@index([status])
  @@index([vesselId])
  @@index([eta])
  @@index([callNo])
  @@index([status, eta])
  @@index([status, ata])
  @@index([shippingAgentId, status])
  @@index([cnfId, status])
  @@index([dischargeStartedAt, status])
  @@map("vessel_calls")
}

model NoticeOfReadiness {
  id                String    @id @default(cuid())
  norNo             String    @unique @map("nor_no")
