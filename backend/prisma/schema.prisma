model StockMovement {
  id                  String             @id @default(cuid())
  movementNo          String             @unique @map("movement_no")
  movementType        StockMovementType  @map("movement_type")
  productId           String             @map("product_id")
  vesselCallId        String?            @map("vessel_call_id")
  lcReleaseId         String?            @map("lc_release_id")
  lighterAssignmentId String?            @map("lighter_assignment_id")
  lighterTripId       String?            @map("lighter_trip_id")
  ghatUnloadingId     String?            @map("ghat_unloading_id")
  siloReceiptId       String?            @map("silo_receipt_id")
  truckLoadId         String?            @map("truck_load_id")
  fromLocationType    StockLocationType? @map("from_location_type")
  fromLocationId      String?            @map("from_location_id")
  toLocationType      StockLocationType? @map("to_location_type")
  toLocationId        String?            @map("to_location_id")
  fromVesselId        String?            @map("from_vessel_id")
  toLighterId         String?            @map("to_lighter_id")
  ghatId              String?            @map("ghat_id")
  siloId              String?            @map("silo_id")
  warehouseId         String?            @map("warehouse_id")
  quantityTon         Decimal            @map("quantity_ton") @db.Decimal(18, 3)
  weightSource        WeightSource?      @map("weight_source")
  movementAt          DateTime           @default(now()) @map("movement_at")
  referenceNo         String?            @map("reference_no")
  operationBatchId    String?            @map("operation_batch_id")
  remarks             String?
  createdAt           DateTime           @default(now()) @map("created_at")

  product           Product             @relation(fields: [productId], references: [id])
  vesselCall        VesselCall?         @relation(fields: [vesselCallId], references: [id])
  lcRelease         LcRelease?          @relation(fields: [lcReleaseId], references: [id])
  lighterAssignment LighterAssignment?  @relation(fields: [lighterAssignmentId], references: [id])
  lighterTrip       LighterTrip?        @relation(fields: [lighterTripId], references: [id])
  ghatUnloading     GhatUnloading?      @relation(fields: [ghatUnloadingId], references: [id])
  siloReceipt       SiloReceipt?        @relation(fields: [siloReceiptId], references: [id])
  truckLoad         TruckLoad?          @relation(fields: [truckLoadId], references: [id])
  fromLocation      Location?           @relation("StockMovementFromLocation", fields: [fromLocationId], references: [id])
  toLocation        Location?           @relation("StockMovementToLocation", fields: [toLocationId], references: [id])
  fromVessel        Vessel?             @relation(fields: [fromVesselId], references: [id])
  toLighter         Lighter?            @relation(fields: [toLighterId], references: [id])
  ghat              Ghat?               @relation(fields: [ghatId], references: [id])
  silo              Silo?               @relation(fields: [siloId], references: [id])
  warehouse         Warehouse?          @relation(fields: [warehouseId], references: [id])
  operationBatch    BulkOperationBatch? @relation("StockMovementBatch", fields: [operationBatchId], references: [id])

  @@index([productId, movementAt])
  @@index([productId, movementAt, id])
  @@index([vesselCallId])
  @@index([lighterTripId])
  @@index([truckLoadId])
  @@index([movementType])
  @@index([fromLocationType, toLocationType])
  @@index([movementType, movementAt])
  @@index([productId, movementType, movementAt])
  @@index([lcReleaseId, movementAt])
  @@index([lighterAssignmentId, movementAt])
  @@index([warehouseId, productId, movementAt])
  @@index([siloId, productId, movementAt])
  @@index([ghatId, productId, movementAt])
  @@index([fromLocationId, movementAt])
  @@index([toLocationId, movementAt])
  @@index([vesselCallId, productId, movementAt])
  @@index([lighterTripId, productId, movementAt])
  @@index([truckLoadId, productId, movementAt])
  @@index([fromLocationType, fromLocationId, productId, movementAt])
  @@index([toLocationType, toLocationId, productId, movementAt])
  @@index([weightSource, movementAt])
  @@index([operationBatchId, movementAt])
  @@index([movementAt, id])
  @@index([createdAt])
  @@index([createdAt, id])
  @@map("stock_movements")
}

model InventoryBalance {
  id               String            @id @default(cuid())
  balanceDate      DateTime          @map("balance_date")
  productId        String            @map("product_id")
  locationType     StockLocationType @map("location_type")
  locationRefId    String            @map("location_ref_id")
