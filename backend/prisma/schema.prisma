// ==================== PRODUCT, PROCUREMENT & CONTRACT ====================

model ProcurementRequest {
  id                  String                   @id @default(cuid())
  requestNo           String                   @unique @map("request_no")
  buyerOrganizationId String?                  @map("buyer_organization_id")
  productId           String                   @map("product_id")
  requestedById       String?                  @map("requested_by_id")
  approvedById        String?                  @map("approved_by_id")
  requiredQtyMt       Decimal                  @map("required_qty_mt") @db.Decimal(18, 3)
  targetPricePerMt    Decimal?                 @map("target_price_per_mt") @db.Decimal(18, 4)
  currency            String?                  @default("USD")
  targetShipmentDate  DateTime?                @map("target_shipment_date")
  targetArrivalDate   DateTime?                @map("target_arrival_date")
  approvalStatus      ProcurementRequestStatus @default(DRAFT) @map("approval_status")
  approvedAt          DateTime?                @map("approved_at")
  remarks             String?
  createdAt           DateTime                 @default(now()) @map("created_at")
  updatedAt           DateTime                 @updatedAt @map("updated_at")

  buyerOrganization Organization?      @relation("ProcurementBuyer", fields: [buyerOrganizationId], references: [id])
  product           Product            @relation(fields: [productId], references: [id])
  requestedBy       User?              @relation("ProcurementRequestedBy", fields: [requestedById], references: [id])
  approvedBy        User?              @relation("ProcurementApprovedBy", fields: [approvedById], references: [id])
  brokerEngagements BrokerEngagement[]
  supplierOffers    SupplierOffer[]
  importPermits     ImportPermit[]

  @@index([buyerOrganizationId])
  @@index([productId])
  @@index([approvalStatus])
  @@index([approvalStatus, targetShipmentDate])
  @@index([productId, createdAt])
  @@map("procurement_requests")
}

model BrokerEngagement {
  id                   String            @id @default(cuid())
  engagementNo         String            @unique @map("engagement_no")
  procurementRequestId String            @map("procurement_request_id")
  brokerOrgId          String            @map("broker_org_id")
  supplierId           String?           @map("supplier_id")
  startDate            DateTime?         @map("start_date")
  endDate              DateTime?         @map("end_date")
  commissionType       String?           @map("commission_type")
  commissionRate       Decimal?          @map("commission_rate") @db.Decimal(10, 4)
  status               NegotiationStatus @default(DRAFT)
  remarks              String?
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")

  procurementRequest ProcurementRequest @relation(fields: [procurementRequestId], references: [id])
  brokerOrg          Organization       @relation("BrokerOrg", fields: [brokerOrgId], references: [id])
  supplier           Organization?      @relation("BrokerSupplier", fields: [supplierId], references: [id])
  supplierOffers     SupplierOffer[]

  @@index([procurementRequestId])
  @@index([brokerOrgId])
  @@index([status])
  @@index([supplierId, status])
  @@index([procurementRequestId, status])
  @@map("broker_engagements")
}

model SupplierOffer {
  id                   String            @id @default(cuid())
  offerNo              String            @unique @map("offer_no")
  procurementRequestId String            @map("procurement_request_id")
  brokerEngagementId   String?           @map("broker_engagement_id")
  supplierId           String            @map("supplier_id")
  productId            String?           @map("product_id")
  offeredQtyMt         Decimal?          @map("offered_qty_mt") @db.Decimal(18, 3)
  pricePerMt           Decimal?          @map("price_per_mt") @db.Decimal(18, 4)
  currency             String?           @default("USD")
  origin               String?
  shipmentWindowFrom   DateTime?         @map("shipment_window_from")
  shipmentWindowTo     DateTime?         @map("shipment_window_to")
  paymentTerms         String?           @map("payment_terms")
  validityDate         DateTime?         @map("validity_date")
  status               NegotiationStatus @default(DRAFT)
  receivedAt           DateTime?         @map("received_at")
  acceptedAt           DateTime?         @map("accepted_at")
  rejectedAt           DateTime?         @map("rejected_at")
  remarks              String?
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")

  procurementRequest ProcurementRequest @relation(fields: [procurementRequestId], references: [id])
  brokerEngagement   BrokerEngagement?  @relation(fields: [brokerEngagementId], references: [id])
  supplier           Organization       @relation("OfferSupplier", fields: [supplierId], references: [id])
  product            Product?           @relation(fields: [productId], references: [id])

  @@index([procurementRequestId])
  @@index([brokerEngagementId])
  @@index([supplierId])
  @@index([status])
  @@index([supplierId, receivedAt])
  @@index([procurementRequestId, status, receivedAt])
  @@map("supplier_offers")
}

model Product {
  id            String      @id @default(cuid())
  code          String      @unique
  name          String
  type          ProductType @default(OTHER)
  specification String?
  defaultUom    String      @default("MT") @map("default_uom")
  hsCode        String?     @map("hs_code")
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  contractLines        ImportContractLine[]
  piItems              PiItem[]
  lcItems              LcItem[]
  blItems              BlItem[]
  vesselCargoLines     VesselCargoLine[]
  tripCargoes          LighterTripCargo[]
  unloadingLines       UnloadingLine[]
  truckLoads           TruckLoad[]
  stockMovements       StockMovement[]
  siloReceipts         SiloReceipt[]
  procurementRequests  ProcurementRequest[]
  supplierOffers       SupplierOffer[]
  permits              ImportPermit[]
  inventoryBalances    InventoryBalance[]
  vesselCargoSummaries VesselCargoSummary[]

  @@index([type])
  @@index([isActive])
  @@index([code, isActive])
  @@map("products")
}

model ImportContract {
  id                     String         @id @default(cuid())
  contractNo             String         @unique @map("contract_no")
  supplierId             String         @map("supplier_id")
  buyerOrganizationId    String?        @map("buyer_organization_id")
  contractDate           DateTime?      @map("contract_date")
  status                 ContractStatus @default(DRAFT)
  totalContractQtyTon    Decimal?       @map("total_contract_qty_ton") @db.Decimal(18, 3)
  pricePerMt             Decimal?       @map("price_per_mt") @db.Decimal(18, 4)
  currency               String?        @default("USD")
  tolerancePercent       Decimal?       @map("tolerance_percent") @db.Decimal(5, 2)
  shipmentFromDate       DateTime?      @map("shipment_from_date")
  shipmentToDate         DateTime?      @map("shipment_to_date")
  lcEstablishByDate      DateTime?      @map("lc_establish_by_date")
  safePortsCount         Int?           @default(1) @map("safe_ports_count")
  safeAnchoragesCount    Int?           @default(2) @map("safe_anchorages_count")
  dischargePort          String?        @map("discharge_port")
  dischargeRateMtPerDay  Decimal?       @map("discharge_rate_mt_per_day") @db.Decimal(18, 2)
  dischargeRateUnit      String?        @default("WEATHER WORKING DAY OF 24 CONSECUTIVE HOURS") @map("discharge_rate_unit")
  /// Laytime demurrage rate per day (same currency as `currency`) for SOF money calc
  laytimeDemurrageRatePerDay Decimal?   @map("laytime_demurrage_rate_per_day") @db.Decimal(18, 4)
  /// Laytime dispatch rate per day when time saved vs allowed (optional CP term)
  laytimeDispatchRatePerDay  Decimal?   @map("laytime_dispatch_rate_per_day") @db.Decimal(18, 4)
  excludedDays           String[]       @default(["FRIDAY", "SATURDAY"]) @map("excluded_days")
  holidaysExcluded       Boolean?       @default(true) @map("holidays_excluded")
  excludedTimePeriod     String?        @map("excluded_time_period")
  remarks                String?
  submittedBySupplierAt  DateTime?      @map("submitted_by_supplier_at")
  approvedById           String?        @map("approved_by_id")
  approvedAt             DateTime?      @map("approved_at")
  sentToSupplierAt       DateTime?      @map("sent_to_supplier_at")
  supplierAcknowledgedAt DateTime?      @map("supplier_acknowledged_at")
  deletedAt              DateTime?      @map("deleted_at")
  createdAt              DateTime       @default(now()) @map("created_at")
  updatedAt              DateTime       @updatedAt @map("updated_at")

  supplier             Organization          @relation("ContractSupplier", fields: [supplierId], references: [id])
  buyer                Organization?         @relation("ContractBuyer", fields: [buyerOrganizationId], references: [id])
  approvedBy           User?                 @relation("ContractApprovedBy", fields: [approvedById], references: [id])
  lines                ImportContractLine[]
  vesselCalls          VesselCall[]
  importPermits        ImportPermit[]
  regulatoryClearances RegulatoryClearance[]

  @@index([supplierId])
  @@index([status])
  @@index([contractNo])
  @@index([approvedById])
  @@index([buyerOrganizationId, status])
  @@index([shipmentFromDate, shipmentToDate])
  @@map("import_contracts")
}

model ImportContractLine {
  id          String   @id @default(cuid())
  contractId  String   @map("contract_id")
  lineNo      Int      @map("line_no")
  productId   String   @map("product_id")
  quantityTon Decimal? @map("quantity_ton") @db.Decimal(18, 3)
  weightTon   Decimal? @map("weight_ton") @db.Decimal(18, 3)
  rate        Decimal? @db.Decimal(18, 4)
  totalAmount Decimal? @map("total_amount") @db.Decimal(18, 2)
  productSpec String?  @map("product_spec")
  lineStatus  String?  @map("line_status")

  contract ImportContract @relation(fields: [contractId], references: [id])
  product  Product        @relation(fields: [productId], references: [id])

  @@unique([contractId, lineNo])
  @@map("import_contract_lines")
}

